{
  "schema_version": 1,
  "language": "zig",
  "types": {
    "int8": "i8",
    "uint8": "u8",
    "int16": "i16",
    "uint16": "u16",
    "int32": "i32",
    "uint32": "u32",
    "int64": "i64",
    "uint64": "u64",
    "float32": "f32",
    "float64": "f64",
    "bool": "bool",
    "str": "[]const u8",
    "None": "void",
    "Any": "pytra.PyObject",
    "Path": "pathlib.Path"
  },
  "generic_types": {
    "list": "pytra.Obj",
    "dict": "std.StringHashMap({V})",
    "set": "std.AutoHashMap({T}, void)",
    "tuple": "struct { {fields} }",
    "optional": "?{T}"
  },
  "operators": {
    "bin": {
      "FloorDiv": "@divFloor",
      "Mod": "@mod",
      "BitAnd": "&",
      "BitOr": "|",
      "BitXor": "^",
      "LShift": "<<",
      "RShift": ">>"
    },
    "cmp": {
      "Eq": "==",
      "NotEq": "!=",
      "Lt": "<",
      "LtE": "<=",
      "Gt": ">",
      "GtE": ">="
    },
    "bool": {
      "And": "and",
      "Or": "or"
    },
    "unary": {
      "Not": "!",
      "Invert": "~"
    }
  },
  "syntax": {
    "if": "if ({cond}) {",
    "elif": "} else if ({cond}) {",
    "else": "} else {",
    "while": "while ({cond}) {",
    "block_close": "}",
    "return": "return",
    "break": "break",
    "continue": "continue",
    "pass": "_ = {}",
    "comment_prefix": "//"
  },
  "lowering": {
    "tuple_unpack_style": "individual_temps",
    "container_covariance": false,
    "closure_style": "closure_syntax",
    "with_style": "defer",
    "property_style": "field_access",
    "swap_style": "temp_var",
    "none_literal": "null",
    "bool_literals": ["true", "false"],
    "self_keyword": "self",
    "type_position": "postfix_colon",
    "condition_parens": true,
    "block_braces": "braces",
    "stmt_terminator": ";",
    "string_type_owned": false,
    "exception_style": "manual_exception_slot"
  }
}
