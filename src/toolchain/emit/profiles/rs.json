{
  "schema_version": 1,
  "language": "rs",

  "types": {
    "int8": "i8",
    "uint8": "u8",
    "int16": "i16",
    "uint16": "u16",
    "int32": "i32",
    "uint32": "u32",
    "int64": "i64",
    "uint64": "u64",
    "float32": "f32",
    "float64": "f64",
    "bool": "bool",
    "str": "String",
    "None": "()",
    "Any": "Box<dyn std::any::Any>",
    "Path": "String"
  },

  "generic_types": {
    "list": "PyList<{T}>",
    "dict": "HashMap<{K}, {V}>",
    "set": "HashSet<{T}>",
    "tuple": "Vec<Box<dyn std::any::Any>>",
    "optional": "Option<{T}>"
  },

  "operators": {
    "bin": {
      "FloorDiv": "__floordiv",
      "Pow": "__pow"
    },
    "bool": {
      "And": "&&",
      "Or": "||"
    },
    "unary": {
      "Not": "!"
    }
  },

  "syntax": {
    "if": "if {cond} {",
    "elif": "} else if {cond} {",
    "else": "} else {",
    "while": "while {cond} {",
    "block_close": "}",
    "return": "return",
    "break": "break",
    "continue": "continue",
    "comment_prefix": "//"
  },

  "lowering": {
    "tuple_unpack_style": "individual_temps",
    "container_covariance": false,
    "closure_style": "closure_syntax",
    "with_style": "raii",
    "property_style": "method_call",
    "swap_style": "temp_var",
    "none_literal": "None",
    "bool_literals": ["true", "false"],
    "self_keyword": "",
    "type_position": "postfix_colon",
    "condition_parens": false,
    "block_braces": "braces",
    "stmt_terminator": ";",
    "string_type_owned": true,
    "exception_style": "panic_catch_unwind"
  }
}
