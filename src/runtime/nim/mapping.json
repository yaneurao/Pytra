    "env.target": "\"nim\"",
    "py_print": "py_print",
    "len": "py_len",
    "str": "py_str",
    "py_to_string": "py_to_string",
    "static_cast": "__CAST__",
    "py_max": "max",
    "py_min": "min",
    "py_int_from_str": "parseInt",
    "set_ctor": "__SET_CTOR__",
    "py_enumerate_object": "py_enumerate",
    "py_reversed_object": "py_reversed",
    "list.append": "__LIST_APPEND__",
    "list.pop": "__LIST_POP__",
    "list.clear": "__LIST_CLEAR__",
    "list.index": "__LIST_INDEX__",
    "dict.get": "__DICT_GET__",
    "dict.items": "__DICT_ITEMS__",
    "dict.keys": "__DICT_KEYS__",
    "dict.values": "__DICT_VALUES__",
    "set.add": "__SET_ADD__",
    "set.discard": "__SET_DISCARD__",
    "set.remove": "__SET_REMOVE__",
    "str.strip": "py_str_strip",
    "str.lstrip": "py_str_lstrip",
    "str.rstrip": "py_str_rstrip",
    "str.startswith": "py_str_startswith",
    "str.endswith": "py_str_endswith",
    "str.replace": "py_str_replace",
    "str.find": "py_str_find",
    "str.split": "py_str_split",
    "str.join": "py_str_join",
    "str.upper": "py_str_upper",
    "str.lower": "py_str_lower",
    "str.isdigit": "py_str_isdigit",
    "str.isalpha": "py_str_isalpha",
    "str.isalnum": "py_str_isalnum",
    "write_rgb_png": "py_write_rgb_png",
    "py_range": "py_range",
    "py_assert_stdout": "py_assert_stdout",
    "py_assert_true": "py_assert_true",
    "py_assert_eq": "py_assert_eq",
    "py_assert_all": "py_assert_all"
  },
  "types": {
    "int8": "int8",
    "uint8": "uint8",
    "int16": "int16",
    "uint16": "uint16",
    "int32": "int32",
    "uint32": "uint32",
    "int64": "int64",
    "uint64": "uint64",
    "float32": "float32",
    "float64": "float64",
    "bool": "bool",
    "str": "string",
    "None": "void",
    "Path": "PyPath",
    "Exception": "ref CatchableError"
  },
  "implicit_promotions": [
    ["uint8", "int64"],
    ["int8", "int64"],
    ["int16", "int64"],
    ["uint16", "int64"],
    ["int32", "int64"],
    ["uint32", "int64"]
  ],
  "skip_modules": [
    "pytra.built_in.",
